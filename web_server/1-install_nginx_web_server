#!/usr/bin/env bash
# 1-install_nginx_web_server
# Installs Nginx, serves "Holberton School" at / on port 80.
# No systemctl per task requirement; uses service.

set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

# Install nginx quietly but reliably
apt-get update -y >/dev/null 2>&1
apt-get install -y nginx >/dev/null 2>&1

# Ensure default index shows the required string
rm -f /var/www/html/index.nginx-debian.html
echo "Holberton School" > /var/www/html/index.html

# Make sure default site is enabled (usually is)
ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Validate config and restart via service (allowed in task)
nginx -t
service nginx restart >/dev/null 2>&1