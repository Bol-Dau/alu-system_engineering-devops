#!/usr/bin/env bash
# Configures Nginx to use a custom 404 page returning a specific string

# Update and install Nginx
apt-get update -y
apt-get install -y nginx

# Create the custom 404 HTML file
echo "Ceci n'est pas une page" > /var/www/html/404.html

# Use sed to insert the error_page directive
# This appends the directive right after the 'server_name _;' line
sed -i '/server_name _;/a \ \terror_page 404 /404.html;' /etc/nginx/sites-available/default

# Restart the service (without systemctl)
service nginx restart